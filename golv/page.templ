package golv

templ renderPage(htmxScriptTag string, body templ.Component) {
  <!doctype html>
  <html lang="fr">
    <head>
      <meta charset="utf-8" />
      <meta name="viewport" content="width=device-width" />
      <title>page title</title>
    </head>
    <body>
   	  @templ.Raw(htmxScriptTag)

      @body
    </body>
  </html>
}
